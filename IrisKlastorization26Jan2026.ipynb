ext\": [","      \"   Метод  Silhouette  Calinski-Harabasz  Davies-Bouldin\\n\",","      \"  KMeans    0.459948         241.904402        0.833595\\n\",","      \"   Agglo    0.446689         222.719164        0.803467\\n\",","      \"Spectral    0.463031         240.972899        0.832467\\n\"","     ]","    }","   ],","   \"source\": [","    \"internal_metrics = []\\n\",","    \"for method, labels in zip(methods, labels_list):\\n\",","    \"    silhouette = silhouette_score(X_scaled, labels)\\n\",","    \"    calinski = calinski_harabasz_score(X_scaled, labels)\\n\",","    \"    davies = davies_bouldin_score(X_scaled, labels)\\n\",","    \"    \\n\",","    \"    internal_metrics.append({\\n\",","    \"        'Метод': method,\\n\",","    \"        'Silhouette': silhouette,\\n\",","    \"        'Calinski-Harabasz': calinski,\\n\",","    \"        'Davies-Bouldin': davies\\n\",","    \"    })\\n\",","    \"\\n\",","    \"internal_df = pd.DataFrame(internal_metrics)\\n\",","    \"print(internal_df.to_string(index=False))\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"id\": \"3ac4b659-fb48-4f2f-a20b-1c487a0cc01b\",","   \"metadata\": {},","   \"source\": [","    \"# Внутренние в сравнении с истиннными\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": 42,","   \"id\": \"c041f97c-d208-4fd1-862e-9baeedb867cc\",","   \"metadata\": {},","   \"outputs\": [","    {","     \"name\": \"stdout\",","     \"output_type\": \"stream\",","     \"text\": [","      \"   Метод  Adjusted Rand      NMI  Homogeneity  Completeness  Accuracy\\n\",","      \"  KMeans       0.620135 0.659487     0.659127      0.659848  0.833333\\n\",","      \"   Agglo       0.615323 0.675470     0.657882      0.694025  0.826667\\n\",","      \"Spectral       0.601791 0.649644     0.647706      0.651594  0.820000\\n\"","     ]","    }","   ],","   \"source\": [","    \"external_metrics = []\\n\",","    \"for method, labels in zip(methods, labels_list):\\n\",","    \"    ari = adjusted_rand_score(y, labels)\\n\",","    \"    nmi = normalized_mutual_info_score(y, labels)\\n\",","    \"    homogeneity = homogeneity_score(y, labels)\\n\",","    \"    completeness = completeness_score(y, labels)\\n\",","    \"    from scipy.optimize import linear_sum_assignment\\n\",","    \"    from sklearn.metrics import confusion_matrix\\n\",","    \"    cm = confusion_matrix(y, labels)\\n\",","    \"    row_ind, col_ind = linear_sum_assignment(-cm)\\n\",","    \"    accuracy = cm[row_ind, col_ind].sum() / len(y)\\n\",","    \"    external_metrics.append({\\n\",","    \"        'Метод': method,\\n\",","    \"        'Adjusted Rand': ari,\\n\",","    \"        'NMI': nmi,\\n\",","    \"        'Homogeneity': homogeneity,\\n\",","    \"        'Completeness': completeness,\\n\",","    \"        'Accuracy': accuracy\\n\",","    \"    })\\n\",","    \"external_df = pd.DataFrame(external_metrics)\\n\",","    \"print(external_df.to_string(index=False))\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"id\": \"387ddeab-4964-4f4a-a037-434090d0299e\",","   \"metadata\": {},","   \"source\": [","    \"# Визуализация в 2D\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": 44,","   \"id\": \"216bcb83-e410-4438-a368-a32589ac826e\",","   \"metadata\": {},","   \"outputs\": [","    {","     \"data\": {","      \"image/png\": \"\",","      \"text/plain\": [","       \"\u003cFigure size 1400x1200 with 4 Axes\u003e\"","      ]","     },","     \"metadata\": {},","     \"output_type\": \"display_data\"","    }","   ],","   \"source\": [","    \"pca = PCA(n_components=2, random_state=42)\\n\",","    \"X_pca = pca.fit_transform(X_scaled)\\n\",","    \"explained_var = pca.explained_variance_ratio_\\n\",","    \"fig, axes = plt.subplots(2, 2, figsize=(14, 12))\\n\",","    \"scatter0 = axes[0, 0].scatter(X_pca[:, 0], X_pca[:, 1], c=y, \\n\",","    \"                              cmap='viridis', s=50, alpha=0.7)\\n\",","    \"axes[0, 0].set_title(f'Истинные классы\\\\n(объясненная дисперсия: {sum(explained_var):.1%})', \\n\",","    \"                    fontsize=12, fontweight='bold')\\n\",","    \"axes[0, 0].set_xlabel(f'PC1 ({explained_var[0]:.1%})')\\n\",","    \"axes[0, 0].set_ylabel(f'PC2 ({explained_var[1]:.1%})')\\n\",","    \"legend0 = axes[0, 0].legend(*scatter0.legend_elements(), \\n\",","    \"                           title=\\\"Виды ирисов\\\", \\n\",","    \"                           loc='upper right')\\n\",","    \"axes[0, 0].add_artist(legend0)\\n\",","    \"\\n\",","    \"# K-Means кластеры\\n\",","    \"scatter1 = axes[0, 1].scatter(X_pca[:, 0], X_pca[:, 1], c=kmeans_labels, \\n\",","    \"                              cmap='Set2', s=50, alpha=0.7)\\n\",","    \"axes[0, 1].set_title('K-Means Clustering', fontsize=12, fontweight='bold')\\n\",","    \"axes[0, 1].set_xlabel(f'PC1 ({explained_var[0]:.1%})')\\n\",","    \"axes[0, 1].set_ylabel(f'PC2 ({explained_var[1]:.1%})')\\n\",","    \"axes[0, 1].legend(*scatter1.legend_elements(), \\n\",","    \"                 title=\\\"Кластеры\\\", \\n\",","    \"                 loc='upper right')\\n\",","    \"\\n\",","    \"# Agglomerative кластеры\\n\",","    \"scatter2 = axes[1, 0].scatter(X_pca[:, 0], X_pca[:, 1], c=agglo_labels, \\n\",","    \"                              cmap='Set3', s=50, alpha=0.7)\\n\",","    \"axes[1, 0].set_title('Agglomerative Clustering', fontsize=12, fontweight='bold')\\n\",","    \"axes[1, 0].set_xlabel(f'PC1 ({explained_var[0]:.1%})')\\n\",","    \"axes[1, 0].set_ylabel(f'PC2 ({explained_var[1]:.1%})')\\n\",","    \"axes[1, 0].legend(*scatter2.legend_elements(), \\n\",","    \"                 title=\\\"Кластеры\\\", \\n\",","    \"                 loc='upper right')\\n\",","    \"\\n\",","    \"# Spectral кластеры\\n\",","    \"scatter3 = axes[1, 1].scatter(X_pca[:, 1], X_pca[:, 0], c=spectral_labels, \\n\",","    \"                              cmap='tab20c', s=50, alpha=0.7)\\n\",","    \"axes[1, 1].set_title('Spectral Clustering', fontsize=12, fontweight='bold')\\n\",","    \"axes[1, 1].set_xlabel(f'PC2 ({explained_var[1]:.1%})')\\n\",","    \"axes[1, 1].set_ylabel(f'PC1 ({explained_var[0]:.1%})')\\n\",","    \"axes[1, 1].legend(*scatter3.legend_elements(), \\n\",","    \"                 title=\\\"Кластеры\\\", \\n\",","    \"                 loc='upper right')\\n\",","    \"\\n\",","    \"for ax in axes.flat:\\n\",","    \"    ax.grid(alpha=0.3)\\n\",","    \"\\n\",","    \"plt.suptitle('СРАВНЕНИЕ КЛАСТЕРИЗАЦИЙ В ПРОСТРАНСТВЕ PCA', \\n\",","    \"             fontsize=16, fontweight='bold', y=1.02)\\n\",","    \"plt.tight_layout()\\n\",","    \"plt.show()\"","   ]","  },","  {","   \"cell_type\": \"markdown\",","   \"id\": \"adea04da-9728-4e73-9dc7-f19bdcadc7c3\",","   \"metadata\": {},","   \"source\": [","    \"# Сравнительная визуализация метрик\\n\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": 46,","   \"id\": \"74b43b03-21ab-4cd5-822a-e1d85f45afb5\",","   \"metadata\": {},","   \"outputs\": [","    {","     \"data\": {","      \"image/png\": \"\",","      \"text/plain\": [","       \"\u003cFigure size 1500x1000 with 6 Axes\u003e\"","      ]","     },","     \"metadata\": {},","     \"output_type\": \"display_data\"","    }","   ],","   \"source\": [","    \"fig, axes = plt.subplots(2, 3, figsize=(15, 10))\\n\",","    \"\\n\",","    \"# Внутренние метрики\\n\",","    \"internal_metrics_to_plot = ['Silhouette', 'Calinski-Harabasz', 'Davies-Bouldin']\\n\",","    \"for idx, metric in enumerate(internal_metrics_to_plot):\\n\",","    \"    axes[0, idx].bar(methods, internal_df[metric], color=['skyblue', 'lightgreen', 'salmon'])\\n\",","    \"    axes[0, idx].set_title(f'{metric}', fontsize=12, fontweight='bold')\\n\",","    \"    axes[0, idx].set_ylabel('Значение')\\n\",","    \"    axes[0, idx].grid(axis='y', alpha=0.3)\\n\",","    \"    for i, (method, value) in enumerate(zip(methods, internal_df[metric])):\\n\",","    \" 